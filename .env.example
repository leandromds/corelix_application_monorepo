# =============================================================================
# Corelix — .env.example
# Fonte de verdade: apps/api/core/config.py (classe Settings)
# =============================================================================
#
# Este arquivo tem dois destinos de cópia com configurações DIFERENTES:
#
#   1. apps/api/.env  — lido pelo Pydantic Settings (env_file=".env" relativo
#      ao CWD, ou seja, relativo a onde `uvicorn` / `pytest` é iniciado).
#      DATABASE_URL deve apontar para localhost (host acessível pela máquina).
#
#   2. .env (raiz do monorepo) — lido pelo Docker Compose para substituição
#      ${VAR}. DATABASE_URL deve usar o service name: @db:5432 (rede interna).
#
# ⚠️  SECRET_KEY e ENCRYPTION_KEY devem COINCIDIR nos dois arquivos.
# ⚠️  DATABASE_URL deve DIFERIR: localhost (Pydantic) vs db:5432 (Docker Compose).
#
# Exemplo de cópia para desenvolvimento local (a partir da raiz do monorepo):
#   cp .env.example apps/api/.env   # Pydantic lê daqui
#   cp .env.example .env            # Docker Compose lê daqui (ajuste DATABASE_URL)
# =============================================================================


# --- Banco de dados ----------------------------------------------------------

# Pydantic (apps/api/.env): aponta para localhost
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/secretaria_digital_dev

# Docker Compose (.env raiz): substitua @localhost:5432 por @db:5432
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/secretaria_digital


# --- Autenticação JWT --------------------------------------------------------
#
# Gerar SECRET_KEY:
#   openssl rand -hex 32
#
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30


# --- Criptografia (dados sensíveis em repouso) -------------------------------
#
# Gerar ENCRYPTION_KEY:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Obrigatório mesmo no modo TerminalProvider — cifra os access_tokens nas
# WhatsAppAccounts. Deve COINCIDIR entre apps/api/.env e .env (raiz).
#
ENCRYPTION_KEY=your-encryption-key-here-generate-with-cryptography-fernet


# --- IA (OpenAI-compatible API) ---------------------------------------------
#
# O serviço de IA é agnóstico de provider: usa o OpenAI SDK com base_url
# configurável. Qualquer endpoint OpenAI-compatible funciona sem alterar código.
#
# Exemplos de configuração:
#   OpenAI (padrão):
#     AI_BASE_URL=https://api.openai.com/v1
#     AI_MODEL=gpt-4o-mini
#
#   OpenRouter (acesso a múltiplos modelos via chave única):
#     AI_BASE_URL=https://openrouter.ai/api/v1
#     AI_MODEL=openai/gpt-4o-mini   # formato provider/model
#
#   DeepSeek:
#     AI_BASE_URL=https://api.deepseek.com/v1
#     AI_MODEL=deepseek-chat
#
#   Groq (inferência rápida):
#     AI_BASE_URL=https://api.groq.com/openai/v1
#     AI_MODEL=llama3-8b-8192
#
#   LiteLLM proxy local:
#     AI_BASE_URL=http://localhost:4000
#     AI_MODEL=gpt-4o-mini
#
AI_API_KEY=sk-your-api-key-here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini


# --- WhatsApp — comuns a todos os providers ----------------------------------
#
# Verificação de webhook (GET hub.challenge) e assinatura HMAC (POST) do
# Meta Cloud API. As variáveis META_* têm PRECEDÊNCIA quando configuradas:
#   _get_app_secret()   usa META_APP_SECRET   ou fallback WHATSAPP_APP_SECRET
#   _get_verify_token() usa META_WEBHOOK_VERIFY_TOKEN ou fallback WHATSAPP_VERIFY_TOKEN
# (ver whatsapp/providers/meta.py para o raciocínio completo)
#
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token-here
WHATSAPP_APP_SECRET=your-app-secret-here
WHATSAPP_APP_ID=your-meta-app-id-here

# WHATSAPP_FORCE_TERMINAL=true força o TerminalProvider para TODOS os profissionais,
# independentemente do WhatsAppAccount configurado no banco.
# Útil para: iteração rápida de prompts, demos ao vivo, testes sem rede.
# ⚠️  NUNCA usar true em produção — TerminalProvider levanta RuntimeError em is_production.
WHATSAPP_FORCE_TERMINAL=false


# --- WhatsApp — Meta Cloud API (produção, número próprio por profissional) ---
#
# Requer aprovação como Meta Tech Provider (ADR-011).
# Quando configurados, META_* têm precedência sobre as variáveis WHATSAPP_*
# correspondentes (ver whatsapp/providers/meta.py: _get_app_secret e _get_verify_token).
# Deixe em branco em desenvolvimento — os fallbacks WHATSAPP_* serão usados.
#
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=


# --- WhatsApp — Twilio Shared Account (DEPRECATED — ver ADR-029) ------------
#
# TwilioSharedAccountProvider usa 1 número Corelix → N profissionais.
# Isso conflita com o requisito de produto de que cada profissional use o
# próprio número WhatsApp. Provider substituído por Dialog360Provider (ADR-029).
#
# Variáveis mantidas aqui porque factory.py ainda usa TwilioSharedAccountProvider
# como fallback — removê-las enquanto o código as referencia causaria falha
# silenciosa em produção. Serão removidas junto com o código na limpeza futura.
#
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_SHARED_PHONE_NUMBER=
TWILIO_WEBHOOK_VALIDATION=true


# --- Aplicação ---------------------------------------------------------------

ENVIRONMENT=development
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000


# --- CORS --------------------------------------------------------------------
#
# Aceita valor único, CSV ou JSON array (todos tratados por _FlexibleEnvSource):
#   CORS_ORIGINS=http://localhost:5173
#   CORS_ORIGINS=http://localhost:5173,http://localhost:3000
#   CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
#
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# --- Observabilidade ---------------------------------------------------------
#
# Glitchtip (Sentry-compatible). Opcional — deixe vazio em desenvolvimento.
# Configure via painel Coolify em produção (nunca comite o DSN real).
#
GLITCHTIP_DSN=


# =============================================================================
# Variáveis injetadas pelo docker-compose.yml (14 no total):
#
#   DATABASE_URL, SECRET_KEY, AI_API_KEY, AI_BASE_URL, AI_MODEL,
#   WHATSAPP_VERIFY_TOKEN, WHATSAPP_APP_SECRET, WHATSAPP_APP_ID,
#   ENVIRONMENT, DEBUG, CORS_ORIGINS, ENCRYPTION_KEY, GLITCHTIP_DSN, API_PORT
#
# ⚠️  Lacuna conhecida: docker-compose.yml NÃO injeta variáveis do ADR-028/029:
#     WHATSAPP_FORCE_TERMINAL, TWILIO_*, META_APP_SECRET, META_WEBHOOK_VERIFY_TOKEN.
#     Adicioná-las ao docker-compose.yml quando necessário para produção.
# =============================================================================
