# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/secretaria_digital_dev

# JWT Authentication
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# AI Provider (OpenAI-compatible API)
AI_API_KEY=sk-your-api-key-here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token-here
WHATSAPP_APP_SECRET=your-app-secret-here

# Força o TerminalProvider para todos os profissionais (dev/test/demo).
# Permite testar o fluxo conversacional de IA sem credenciais Meta/Twilio.
# NUNCA usar true em produção.
WHATSAPP_FORCE_TERMINAL=false

# Application
ENVIRONMENT=development
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Encryption (for storing sensitive data like WhatsApp tokens)
ENCRYPTION_KEY=your-encryption-key-here-generate-with-cryptography-fernet

# WhatsApp App ID (required for Embedded Signup token exchange)
WHATSAPP_APP_ID=your-meta-app-id-here

# Observability — Glitchtip (Sentry-compatible error tracking)
# Optional — leave empty in development, set in production via Coolify panel
GLITCHTIP_DSN=
