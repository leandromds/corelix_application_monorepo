# API base URL — used by src/services/api.ts
# In development: uses the Vite proxy (/api → localhost:8000), no change needed.
# In production: set to your deployed API URL (e.g. https://api.corelix.com/api/v1)
VITE_API_URL=/api/v1

# Observability — Glitchtip/Sentry (error tracking + session replay)
# Optional — leave empty in development. Set in Coolify panel for production.
VITE_GLITCHTIP_DSN=

# Environment name — used by Sentry to distinguish dev/staging/prod errors
VITE_ENVIRONMENT=development

# PostHog (product analytics + session recording)
# Optional — leave empty in development. Get key at app.posthog.com.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
